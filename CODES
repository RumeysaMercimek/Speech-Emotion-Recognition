        "def augment_audio(audio, sr):\n",
        "    # Ensure audio is mono and float32\n",
        "    audio = audio.astype(np.float32)\n",
        "\n",
        "    # Time stretching (librosa requires audio length > frame length)\n",
        "    if random.random() < 0.3 and len(audio) > 2048:\n",
        "        try:\n",
        "            audio = librosa.effects.time_stretch(audio, rate=random.uniform(0.8, 1.2))\n",
        "        except:\n",
        "            pass  # Fallback if stretching fails\n",
        "\n",
        "    # Pitch shifting\n",
        "    if random.random() < 0.3:\n",
        "        n_steps = random.randint(-2, 2)\n",
        "        audio = librosa.effects.pitch_shift(y=audio, sr=sr, n_steps=n_steps)\n",
        "\n",
        "    # Add Gaussian noise\n",
        "    if random.random() < 0.3:\n",
        "        noise = np.random.normal(0, 0.005, audio.shape)\n",
        "        audio += noise\n",
        "\n",
        "    return audio\n",
        "\n",
        "def trim_audio(audio, sr, n_sec):\n",
        "\n",
        "    # Calculate the number of samples for n_sec seconds\n",
        "    second_samples = int(n_sec * sr)\n",
        "\n",
        "    # Trim  n_sec seconds from start and end\n",
        "    if len(audio) > 2 * second_samples:\n",
        "        audio_trimmed = audio[second_samples:-second_samples]\n",
        "    else:\n",
        "        # If audio is too short, return the original or handle as needed\n",
        "        audio_trimmed = audio\n",
        "\n",
        "    return audio_trimmed\n",
        "\n",
        "def resize_mfcc(mfcc, max_pad_len):\n",
        "     # Pad or truncate MFCC\n",
        "    if mfcc.shape[1] < max_pad_len:\n",
        "        pad_width = max_pad_len - mfcc.shape[1]\n",
        "        mfcc = np.pad(mfcc, pad_width=((0, 0), (0, pad_width)), mode='constant')\n",
        "    else:\n",
        "        mfcc = mfcc[:, :max_pad_len]\n",
        "\n",
        "    return mfcc\n",
        "\n",
        "def normalize_mfcc(mfcc):\n",
        "    scaler = StandardScaler()\n",
        "    return scaler.fit_transform(mfcc.T).T\n",
        "\n",
        "# confusion matrix visualization function from sklearn documentation\n",
        "\n",
        "import itertools\n",
        "\n",
        "def plot_confusion_matrix(cm, classes,\n",
        "                          normalize=False,\n",
        "                          title='Confusion matrix',\n",
        "                          cmap=plt.cm.Blues):\n",
        "    \"\"\"\n",
        "    This function prints and plots the confusion matrix.\n",
        "    Normalization can be applied by setting `normalize=True`.\n",
        "    \"\"\"\n",
        "    plt.imshow(cm, interpolation='nearest', cmap=cmap)\n",
        "    plt.title(title)\n",
        "    plt.colorbar()\n",
        "    tick_marks = np.arange(len(classes))\n",
        "    plt.xticks(tick_marks, classes, rotation=45)\n",
        "    plt.yticks(tick_marks, classes)\n",
        "\n",
        "    if normalize:\n",
        "        cm = cm.astype('float') / cm.sum(axis=1)[:, np.newaxis]\n",
        "        print(\"Normalized confusion matrix\")\n",
        "    else:\n",
        "        print('Confusion matrix, without normalization')\n",
        "\n",
        "    # print(cm)\n",
        "\n",
        "    thresh = cm.max() / 2.\n",
        "    for i, j in itertools.product(range(cm.shape[0]), range(cm.shape[1])):\n",
        "        plt.text(j, i, cm[i, j],\n",
        "                 horizontalalignment=\"center\",\n",
        "                 color=\"white\" if cm[i, j] > thresh else \"black\")\n",
        "    plt.tight_layout()\n",
        "    plt.ylabel('True label')\n",
        "    plt.xlabel('Predicted label')\n"
      ]
